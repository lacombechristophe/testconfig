# ─── Resend (https://resend.com) ─────────────────────────────────────────────
# Clé API Resend — obtenir sur https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret dédié à la dérivation des clés de stockage (RESEND_API_KEY est utilisé en repli)
KEY_DERIVATION_SECRET=replace_with_a_long_random_secret

# Email expéditeur — doit correspondre à un domaine vérifié dans Resend
# Ex: contact@diskoov.fr ou noreply@diskoov.fr
FROM_EMAIL=contact@diskoov.fr

# Email de réception des leads internes (peut être le même)
INTERNAL_EMAIL=xavier.dispot@diskoov.fr

# ─── Contact (affiché dans les emails de confirmation) ───────────────────────
# Si non renseigné, les valeurs par défaut sont utilisées
PUBLIC_CONTACT_NAME=L'équipe Diskoov
PUBLIC_CONTACT_EMAIL=contact@diskoov.fr
CONTACT_PHONE=06 20 54 25 04
CONTACT_LOC=Conseil et étude personnalisée
CONTACT_ADDR=494, rue Léon Blum 34 000 Montpellier
SITE_URL=https://diskoov.fr
LOGO_URL=https://configurateur.diskoov.fr/assets/marque/logo-diskoov-bleu-orange.png

# Vercel KV (rate-limiting persistant) — ajouté automatiquement si vous activez KV dans Vercel
KV_REST_API_URL=
KV_REST_API_TOKEN=
